# ============================================
# AI Sports Editor - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# ---- Application ----
NODE_ENV=development
APP_NAME=ai-sports-editor
APP_PORT=4000
FRONTEND_URL=http://localhost:3000

# ---- Database (PostgreSQL) ----
POSTGRES_USER=sports_editor
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=sports_editor_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# ---- Authentication (JWT) ----
JWT_SECRET=your_jwt_secret_min_32_chars_here
JWT_EXPIRES_IN=7d
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# ---- AI Service (Python FastAPI) ----
AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_API_KEY=your_internal_api_key_here

# ---- AI Model Provider ----
# Options: "openai" or "gemini"
AI_PROVIDER=gemini

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# Google Gemini Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ---- Whisper Configuration ----
# Options: "local" (faster-whisper, free) or "api" (OpenAI Whisper API, paid)
WHISPER_MODE=local
WHISPER_MODEL_SIZE=base

# ---- Video Processing ----
MAX_VIDEO_DURATION=3600
MAX_UPLOAD_SIZE=2147483648
VIDEO_STORAGE_PATH=/app/storage/videos
EXPORT_STORAGE_PATH=/app/storage/exports
TEMP_STORAGE_PATH=/app/storage/temp

# ---- YouTube Download ----
# Rate limiting for yt-dlp requests
YTDLP_RATE_LIMIT=5M
YTDLP_MAX_RETRIES=3

# ---- Logging ----
LOG_LEVEL=info
LOG_FORMAT=json

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:4000
